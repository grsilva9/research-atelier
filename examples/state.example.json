        "title": { "maturity": 3, "notes": "Working title: Contrastive Learning under Distribution Shift. Could also be 'Density-Reweighted InfoNCE.'" },
        "gap": { "maturity": 4, "notes": "Existing contrastive methods assume iid data; we look at the shift case. The gap is real and underexplored." },
        "hypothesis": { "maturity": 3, "notes": "H1: the InfoNCE bound tightens under a reweighted sampling scheme. H2: reweighting improves downstream transfer under covariate shift." },
